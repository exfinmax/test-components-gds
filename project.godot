; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

autoload={
"SaveSystem": "res://addons/save_system/Core/save_system.gd"
}

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="test_components"
run/main_scene="uid://cs6hy7jrf3oqk"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://ComponentLibrary/Core/events/event_bus.gd"
ObjectPool="*res://ComponentLibrary/Core/pools/object_pool.gd"
TimeController="*res://ComponentLibrary/Core/time/time_controller.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
GuiTransitions="*res://addons/simple-gui-transitions/singleton.gd"
SaveSystem="*uid://bv1y5o6lgq7yi"

[display]

window/size/always_on_top=true
window/subwindows/embed_subwindows=false

[dotnet]

project/assembly_name="test_components"

[editor_plugins]

enabled=PackedStringArray("res://addons/assetplus/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/enhance_save_system/plugin.cfg", "res://addons/godot_mcp/plugin.cfg", "res://addons/polygon2d_tool/plugin.cfg", "res://addons/procedural_tex/plugin.cfg", "res://addons/simple-gui-transitions/plugin.cfg")

[godot_mcp]

bind_mode=0
custom_bind_ip=""
port_override_enabled=false
port_override=6550

[gui_transitions]

config/default/auto_start=true
config/default/fade_layout=true
config/default/center_pivot=true
config/default/duration=0.5
config/default/delay=0.5
config/default/transition_type="QUAD"
config/default/ease_type="IN_OUT"
config/default/animation_enter=4
config/default/animation_leave=4

